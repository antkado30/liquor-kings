# Liquor Kings API — environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to git.

# Supabase
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Server
PORT=4000

# Sentry (optional — leave empty to disable error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# MLCC RPA credentials
MLCC_PASSWORD=your-mlcc-password-here
MLCC_SEED_STORE_USERNAME=your-mlcc-username-here

# MLCC RPA URLs — do not change unless MLCC portal changes
MLCC_LOGIN_URL=https://www.lara.michigan.gov/milo/auth/sign-in
MLCC_SAFE_TARGET_URL=https://www.lara.michigan.gov/milo/home
MLCC_ORDERING_ENTRY_URL=https://www.lara.michigan.gov/milo/products

# RPA behaviour
MLCC_RECON_MODE=true
