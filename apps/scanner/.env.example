# Scanner environment configuration
# DEV ONLY — Phase B #4 (customer signup) replaces these with real Supabase JWT auth.

# Supabase service role bearer for /cart and /execution-runs auth (DEV ONLY).
# Copy from services/api/.env (SUPABASE_SERVICE_ROLE_KEY).
# WARNING: this key is bundled into the client build. Never deploy with this populated to production.
VITE_SCANNER_DEV_BEARER=

# Store UUID this scanner instance acts as (single-store dev mode).
VITE_SCANNER_STORE_ID=00000000-0000-0000-0000-000000000001

# Optional API base URL (defaults to "" for same-origin via Vite proxy).
VITE_SCANNER_API_BASE=

# Optional UPC mapping confirmation token (existing).
VITE_UPC_CONFIRM_TOKEN=
