# Scanner environment configuration.
#
# Auth: real Supabase Auth — the user signs in via the AuthGate login
# screen, the JWT lives in supabase.auth.getSession(), and the previous
# bundled-service-role dev hack is GONE. Service role keys never ship to
# the client bundle.

# Supabase project URL — copy from services/api/.env (SUPABASE_URL).
# Safe to ship in the client bundle.
VITE_SUPABASE_URL=

# Supabase anon (publishable) key — copy from your Supabase project's
# API settings page. INTENDED to be public; RLS policies are what actually
# authorize requests. NEVER use the service role key here.
VITE_SUPABASE_ANON_KEY=

# Store UUID this scanner instance is bound to (V1 single-store deploy).
# Server-side resolveAuthenticatedStore middleware enforces the signed-in
# user actually has a store_users membership row for this store_id.
VITE_SCANNER_STORE_ID=00000000-0000-0000-0000-000000000001

# Optional API base URL (defaults to "" for same-origin via Vite proxy).
VITE_SCANNER_API_BASE=

# Optional UPC mapping confirmation token (existing).
VITE_UPC_CONFIRM_TOKEN=
